@using VuexyBase.Application.Application.Contracts.Application.Dashboard.City
@using VuexyBase.Application.Application.ViewModels.City

@model UpdateCityViewModel;

<div id="form-edit">

    <form id="Edit-city-form">

        <input type="hidden" id="edit-id" name="Id" asp-for="@Model.Id" />

        <div class="mb-3">
            <labe for="edit-name-en" class="form-label">
                Name (EN) </label>
                <input type="text" class="form-control" id="edit-name-en" asp-for="@Model.NameEn" />

                <span asp-validation-for="NameEn"></span>

        </div>

        <div class="mb-3">
            <label for="edit-name-ar" class="form-label">Name (AR)</label>
            <input type="text" class="form-control" id="edit-name-ar" name="NameAr" asp-for="@Model.NameAr" />
            <span asp-validation-for="NameAr"></span>

        </div>

        <div class="mb-3">
            <label class="form-label">Choose the main region</label>
            <select class="form-select" asp-for="RegionId" id="edit-RegionId" asp-items="@ViewBag.Regions">
                <option value="0">Choose Region</option>
            </select>
        </div>

        <div class="mb-3">
            <label for="edit-is-active" class="form-label">Is Active</label>
            <select id="edit-is-active" name="IsActive" class="form-select" asp-for="@Model.IsActive">
                <option value="true">Active</option>
                <option value="false">Inactive</option>
            </select>
            <span asp-validation-for="IsActive"></span>

        </div>

        <button type="submit" class="btn btn-primary">@Localization["save"]</button>

    </form>

</div>

<script>

    document.addEventListener("DOMContentLoaded", function () {
        const form = document.getElementById("Edit-city-form");

        form.addEventListener("submit", async function (event) {

            // Prevents the browser's default form submission (which would reload the page).
            event.preventDefault();

            const submitButton = form.querySelector("button[type='submit']");
            submitButton.disabled = true;

            const formData = new FormData(form);

            try {
                const response = await fetch("@Url.Action("Edit", "City")", {
                    method: "POST",
                    body: formData
                });

                if (!response.ok) {
                    throw new Error("Failed to submit the form");
                }

                const html = await response.text();

                document.getElementById("form-edit").innerHTML = html;

                 const trigger = response.headers.get("HX-Trigger");
                 console.log(trigger);

                // Handle trigger logic
                if (trigger === "cityUpdated") {
                    fetch('@Url.Action("GetTablePartial", "City")')
                        .then(res => res.text())
                        .then(html => document.getElementById("table-container").innerHTML = html);

                    // Refresh form
                    fetch('@Url.Action("GetEditTablePartial", "City")')
                        .then(res => res.text())
                        .then(html => document.getElementById("form-edit") = html);
                        }

                const offcanvas = bootstrap.Offcanvas.getInstance(document.getElementById('offcanvasEditData'));
                if (offcanvas) offcanvas.hide();

            } catch (error) {
                console.error("Submission error:", error);
            } finally {
                submitButton.disabled = false;
            }
        });
    });
</script>